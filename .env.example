# Server
PORT=5000
NODE_ENV=development
# Railway/production: set NODE_ENV=production (or rely on RAILWAY_ENVIRONMENT for trust proxy)

# MongoDB — use placeholders in commits; real URI only in local .env
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/fixitnow?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
USE_REFRESH_TOKENS=true
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# CORS - comma separated origins
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# Super Admin only (env-only login — not stored in MongoDB; regular admins use Mongo)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_PHONE=03XXXXXXXXX
SUPER_ADMIN_PIN=<your-8-digit-pin>

# Redis (Optional)
REDIS_URL=
REDIS_PASSWORD=

# OpenStreetMap geocoding
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=FixItNow/1.0 (contact@yourdomain.com)

# Logging
LOG_LEVEL=info

# Email — Resend HTTP API (Railway-friendly; no SMTP ports)
# Sign up: https://resend.com → API Keys → add & verify your domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Use onboarding@resend.dev for quick tests; production: noreply@yourdomain.com
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Fix It Now

# Frontend URLs
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

# Web Push (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@fixitnow.app
