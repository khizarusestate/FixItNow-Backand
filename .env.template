VITE_APP_NAME=FixItNow Admin
VITE_APP_VERSION=1.0.0


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 QUICK REFERENCE GUIDE
# ═══════════════════════════════════════════════════════════════════════════════

# PRODUCTION DEPLOYMENT:
# ───────────────────────────────────────────────────────────────────────────────
#
# Backend:
#   Location: /var/www/backend/.env (or your backend path)
#   Keys to update:
#     - MONGODB_URI: Your MongoDB connection string
#     - JWT_SECRET: Strong random string (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
#     - RESEND_API_KEY: Your email API key
#     - FRONTEND_URL: https://fixitnow.pk
#     - ADMIN_FRONTEND_URL: https://admin.fixitnow.pk
#
# Frontend:
#   Location: /var/www/fixitnow/.env (or your frontend path)
#   Keys to update:
#     - VITE_API_BASE_URL: https://fixitnow.pk/api
#     - VITE_SOCKET_URL: https://fixitnow.pk
#     - VITE_GOOGLE_CLIENT_ID: Your Google OAuth ID
#     - VITE_GOOGLE_MAPS_API_KEY: Your Google Maps key
#
# Admin Panel:
#   Location: /var/www/FixItNow-AdminPanal/.env
#   Keys to update:
#     - VITE_API_BASE_URL: https://admin.fixitnow.pk/api
#     - VITE_SOCKET_URL: https://fixitnow.pk
#     - VITE_GOOGLE_CLIENT_ID: Your Google OAuth ID


# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════════

# ⚠️  NEVER commit .env files to Git
# ⚠️  Use strong random values for all SECRET keys
# ⚠️  Keep API keys confidential
# ⚠️  Rotate secrets regularly in production
# ⚠️  Use environment variables from CI/CD pipeline for secrets
# ⚠️  Don't share .env files via email or chat


# ═══════════════════════════════════════════════════════════════════════════════
# 📝 EXAMPLES & EXPLANATIONS
# ═══════════════════════════════════════════════════════════════════════════════

#
# FRONTEND_URL=https://fixitnow.pk
#   ↳ Where your customer-facing app is hosted
#   ↳ Used for CORS, redirects, and email links
#   ↳ Example: User clicks link in email → takes them to https://fixitnow.pk
#
# VITE_API_BASE_URL=https://fixitnow.pk/api
#   ↳ Your backend API server address
#   ↳ Frontend makes all API calls to this URL
#   ↳ Example: Booking requests → https://fixitnow.pk/api/bookings
#
# VITE_SOCKET_URL=https://fixitnow.pk
#   ↳ WebSocket server for real-time notifications
#   ↳ Frontend connects to receive live updates
#   ↳ Example: New booking notification arrives instantly
#
# VITE_PLATFORM_BANK_ACCOUNT_TITLE=Tahir Ayyub
#   ↳ Account holder name shown to users
#   ↳ For bank transfers display
#   ↳ Change to your actual account holder name
#
# VITE_PLATFORM_JAZZCASH_MSISDN=03001234567
#   ↳ JazzCash account number (mobile number)
#   ↳ For JazzCash payment instructions
#   ↳ Change to your actual JazzCash number
#


# ═══════════════════════════════════════════════════════════════════════════════
# 🚀 DEPLOYMENT COMMANDS
# ═══════════════════════════════════════════════════════════════════════════════

#
# 1. SSH into VPS
#    ssh root@your-server-ip
#
# 2. Navigate to backend directory
#    cd /var/www/fixitnow-backend
#
# 3. Create/edit .env file
#    nano .env
#    (Copy backend section from above)
#
# 4. Test backend starts
#    npm start
#
# 5. Navigate to frontend directory
#    cd /var/www/fixitnow
#
# 6. Create/edit .env file
#    nano .env
#    (Copy frontend section from above)
#
# 7. Build frontend
#    npm run build
#
# 8. Navigate to admin panel directory
#    cd /var/www/FixItNow-AdminPanal
#
# 9. Create/edit .env file
#    nano .env
#    (Copy admin panel section from above)
#
# 10. Build admin panel
#     npm run build
#
# 11. Restart services
#     sudo systemctl restart fixitnow-backend
#     sudo systemctl restart nginx (or your web server)
#
# 12. Verify deployment
#     curl https://fixitnow.pk
#     curl https://admin.fixitnow.pk
#


