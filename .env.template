################################################################################
#                                                                              #
#                    FIXITNOW - ENVIRONMENT VARIABLES GUIDE                  #
#                                                                              #
#              Complete configuration for Backend, Frontend & Admin Panel     #
#              Use this file as reference for setting up your VPS            #
#                                                                              #
################################################################################


# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 BACKEND ENVIRONMENT VARIABLES (.env)
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fixitnow?retryWrites=true&w=majority
DB_NAME=fixitnow

# ───────────────────────────────────────────────────────────────────────────────
# JWT & AUTHENTICATION
# ───────────────────────────────────────────────────────────────────────────────

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production

# ───────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (Resend API)
# ───────────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=re_your_resend_api_key_here
SENDER_EMAIL=noreply@fixitnow.pk
SENDER_NAME=FixItNow

# ───────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (Optional - for social login)
# ───────────────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ───────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=production

# ───────────────────────────────────────────────────────────────────────────────
# CORS CONFIGURATION (Frontend Domains)
# ───────────────────────────────────────────────────────────────────────────────

CLIENT_ORIGINS=https://fixitnow.pk,https://fixitnow.cloud,https://admin.fixitnow.pk,https://admin.fixitnow.cloud,http://localhost:3000,http://localhost:5173,http://localhost:5174

FRONTEND_URL=https://fixitnow.pk
ADMIN_FRONTEND_URL=https://admin.fixitnow.pk

# ───────────────────────────────────────────────────────────────────────────────
# SOCKET.IO CONFIGURATION (WebSocket)
# ───────────────────────────────────────────────────────────────────────────────

VITE_SOCKET_URL=https://fixitnow.pk

# ───────────────────────────────────────────────────────────────────────────────
# PAYMENT CONFIGURATION (Bank & JazzCash)
# ───────────────────────────────────────────────────────────────────────────────

VITE_PLATFORM_BANK_ACCOUNT_TITLE=Tahir Ayyub
VITE_PLATFORM_BANK_NAME=HBL
VITE_PLATFORM_BANK_ACCOUNT_NUMBER=01234567890123
VITE_PLATFORM_BANK_IBAN=PK00DEMO0000001234567890
VITE_PLATFORM_JAZZCASH_MSISDN=03001234567
VITE_PLATFORM_WALLET_MSISDN=03001234567

# ───────────────────────────────────────────────────────────────────────────────
# LOGGING & DEBUG (Optional)
# ───────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info
DEBUG=false

# ───────────────────────────────────────────────────────────────────────────────
# FILE UPLOADS (Optional - for production S3/Cloudinary)
# ───────────────────────────────────────────────────────────────────────────────

# CLOUDINARY_CLOUD_NAME=your-cloudinary-name
# CLOUDINARY_API_KEY=your-cloudinary-key
# CLOUDINARY_API_SECRET=your-cloudinary-secret

# AWS_S3_BUCKET=fixitnow-uploads
# AWS_S3_REGION=ap-southeast-1
# AWS_S3_ACCESS_KEY=your-access-key
# AWS_S3_SECRET_KEY=your-secret-key


# ═══════════════════════════════════════════════════════════════════════════════
